<div class="loading-card @Class" role="status" aria-live="polite">
    <div class="loading-pulse" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
    </div>
    <span>@Message</span>
</div>

@code {
    [Parameter]
    public string Message { get; set; } = "Loading...";

    [Parameter]
    public string? Class { get; set; }
}
