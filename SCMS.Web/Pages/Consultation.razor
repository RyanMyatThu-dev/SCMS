@page "/consultation"
@page "/consultation/{AppointmentId:int}"
@attribute [Authorize(Roles = "admin,doctor")]
@inject ApiClient Api

<PageTitle>Consultation</PageTitle>

<PageHeader Title="Consultation EMR" Subtitle="Patient history, vitals, prescription safety, labs, and follow-up.">
    <PageHeaderExtra>
        <Button OnClick="Load">Refresh</Button>
    </PageHeaderExtra>
</PageHeader>

<AntDesign.Row Gutter="24">
    <AntDesign.Col Span="16">
        <Card>
            <Steps Current="currentStep">
                <Step Title="Vitals & History" />
                <Step Title="Diagnosis & Notes" />
                <Step Title="Prescription & Follow-up" />
            </Steps>
            <Divider />
            
            <div style="min-height: 300px;">
                @if (currentStep == 0)
                {
                    <div style="margin-bottom: 16px;">
                        <span style="font-weight: bold;">Appointment</span>
                        <Select TItem="AppointmentDetailsResponse" TItemValue="int" @bind-Value="selectedAppointmentId" 
                                DataSource="appointments" ValueName="@nameof(AppointmentDetailsResponse.Id)" 
                                OnSelectedItemChanged="SelectAppointmentHandler" Style="width: 100%; margin-top: 8px;" Placeholder="Select appointment">
                            <ItemTemplate Context="appt">
                                @appt.TokenNumber - @appt.PatientName - @appt.Datetime.ToString("MMM dd HH:mm")
                            </ItemTemplate>
                        </Select>
                    </div>

                    @if (history != null)
                    {
                        <Alert Type="@AlertType.Info" Message="@($"{history.PatientName} | Allergies: {(summary?.Allergies ?? "None")} | Chronic: {(summary?.ChronicConditions ?? "None")}")" Style="margin-bottom: 16px;" />
                    }

                    <AntDesign.Row Gutter="16">
                        <AntDesign.Col Span="8">
                            <span style="font-weight: bold;">Weight (kg)</span>
                            <AntDesign.InputNumber @bind-Value="prescription.WeightKg" Style="width:100%" />
                        </AntDesign.Col>
                        <AntDesign.Col Span="8">
                            <span style="font-weight: bold;">Height (cm)</span>
                            <AntDesign.InputNumber @bind-Value="prescription.HeightCm" Style="width:100%" />
                        </AntDesign.Col>
                        <AntDesign.Col Span="8">
                            <span style="font-weight: bold;">Temp (C)</span>
                            <AntDesign.InputNumber @bind-Value="prescription.TemperatureC" Style="width:100%" />
                        </AntDesign.Col>
                    </AntDesign.Row>
                    <AntDesign.Row Gutter="16" Style="margin-top: 16px;">
                        <AntDesign.Col Span="8">
                            <span style="font-weight: bold;">Pulse (bpm)</span>
                            <AntDesign.InputNumber @bind-Value="prescription.PulseBpm" Style="width:100%" />
                        </AntDesign.Col>
                        <AntDesign.Col Span="8">
                            <span style="font-weight: bold;">SpO2 (%)</span>
                            <AntDesign.InputNumber @bind-Value="prescription.Spo2Percent" Style="width:100%" />
                        </AntDesign.Col>
                        <AntDesign.Col Span="8">
                            <span style="font-weight: bold;">BP (Sys/Dia)</span>
                            <div style="display:flex; gap: 8px;">
                                <AntDesign.InputNumber @bind-Value="prescription.BloodPressureSystolic" Style="width:100%" />
                                <span>/</span>
                                <AntDesign.InputNumber @bind-Value="prescription.BloodPressureDiastolic" Style="width:100%" />
                            </div>
                        </AntDesign.Col>
                    </AntDesign.Row>
                    <div style="margin-top: 24px; text-align: right;">
                        <Button Type="@ButtonType.Primary" OnClick="NextStep" Disabled="selectedAppointmentId == 0">Next</Button>
                    </div>
                }
                else if (currentStep == 1)
                {
                    <div style="margin-bottom: 16px;">
                        <span style="font-weight: bold;">Diagnosis</span>
                        <Select TItem="DiseaseResponse" TItemValue="int?" @bind-Value="prescription.DiseaseId"
                                DataSource="diseases" ValueName="@nameof(DiseaseResponse.Id)" LabelName="@nameof(DiseaseResponse.Name)"
                                Style="width: 100%; margin-top: 8px;" Placeholder="General consultation" />
                    </div>
                    <div style="margin-bottom: 16px;">
                        <span style="font-weight: bold;">Notes</span>
                        <TextArea @bind-Value="prescription.Notes" Rows="4" Style="width: 100%; margin-top: 8px;" />
                    </div>
                    <div style="margin-bottom: 16px;">
                        <span style="font-weight: bold;">Lab tests</span>
                        <TextArea @bind-Value="prescription.LabTestRequests" Rows="2" Style="width: 100%; margin-top: 8px;" />
                    </div>
                    <div style="margin-top: 24px; text-align: right;">
                        <Space>
                            <SpaceItem><Button OnClick="PrevStep">Previous</Button></SpaceItem>
                            <SpaceItem><Button Type="@ButtonType.Primary" OnClick="NextStep">Next</Button></SpaceItem>
                        </Space>
                    </div>
                }
                else if (currentStep == 2)
                {
                    <div style="margin-bottom: 16px;">
                        <span style="font-weight: bold;">Medicines</span>
                        <Table TItem="PrescriptionItemDto" DataSource="prescription.Items" Size="TableSize.Small">
                            <Column TData="int" Title="Medicine">
                                <Select TItem="MedicineSearchResponse" TItemValue="int" @bind-Value="context.MedicineId" 
                                        DataSource="medicines" ValueName="@nameof(MedicineSearchResponse.MedicineId)" LabelName="@nameof(MedicineSearchResponse.Name)" Style="width: 100%;" />
                            </Column>
                            <Column TData="int" Title="Qty"><AntDesign.InputNumber @bind-Value="context.Quantity" Style="width: 60px;" /></Column>
                            <Column TData="int" Title="Days"><AntDesign.InputNumber @bind-Value="context.Days" Style="width: 60px;" /></Column>
                            <Column TData="string" Title="Dose"><Input @bind-Value="context.Dosage" /></Column>
                            <Column TData="string" Title="Timing"><Input @bind-Value="context.MealTiming" /></Column>
                            <ActionColumn Title="Actions"><Button Danger Size="@ButtonSize.Small" OnClick="() => RemoveItem(context)">X</Button></ActionColumn>
                        </Table>
                        <Button Style="margin-top: 8px;" OnClick="AddItem">Add medicine</Button>
                    </div>

                    <Divider />
                    
                    <AntDesign.Row Gutter="16">
                        <AntDesign.Col Span="8">
                            <span style="font-weight: bold;">Follow-up Date</span>
                            <DatePicker @bind-Value="followUpDate" Style="width: 100%; margin-top: 8px;" />
                        </AntDesign.Col>
                        <AntDesign.Col Span="16">
                            <span style="font-weight: bold;">Recommendation</span>
                            <Input @bind-Value="followUpRecommendation" Style="width: 100%; margin-top: 8px;" />
                        </AntDesign.Col>
                    </AntDesign.Row>

                    <div style="margin-top: 24px; text-align: right;">
                        <Space>
                            <SpaceItem><Button OnClick="PrevStep">Previous</Button></SpaceItem>
                            <SpaceItem><Button OnClick="SaveTemplate">Save Template</Button></SpaceItem>
                            <SpaceItem><Button Type="@ButtonType.Primary" OnClick="CreatePrescription" Loading="isSubmitting">Submit Prescription</Button></SpaceItem>
                        </Space>
                    </div>
                    
                    @if (createdPrescription != null)
                    {
                        <Alert Type="@AlertType.Success" Message="@($"Prescription #{createdPrescription.Id} created")" ShowIcon="true" Style="margin-top: 16px;">
                            <DescriptionTemplate>
                                <Button Size="@ButtonSize.Small" OnClick="() => DownloadPrescription(createdPrescription.Id)">Prescription PDF</Button>
                                @foreach (var warning in createdPrescription.Warnings)
                                {
                                    <div style="color: red; margin-top: 8px;">@warning</div>
                                }
                            </DescriptionTemplate>
                        </Alert>
                    }
                    @if (!string.IsNullOrWhiteSpace(message))
                    {
                        <Alert Type="@AlertType.Info" Message="@message" ShowIcon="true" Style="margin-top: 16px;" />
                    }
                }
            </div>
        </Card>
    </AntDesign.Col>
    <AntDesign.Col Span="8">
        <Card Title="History" Style="margin-bottom: 16px;">
            <Timeline>
                @foreach (var item in history?.Timeline.Take(8) ?? new List<TimelineItemDto>())
                {
                    <TimelineItem Color="@("blue")">
                        <p><strong>@item.Type</strong> - @item.Date.ToString("MMM dd yyyy")</p>
                        <p>@item.Title</p>
                    </TimelineItem>
                }
            </Timeline>
        </Card>
        <Card Title="Templates">
            <List TItem="PrescriptionTemplateResponse">
                @foreach (var templateItem in templates)
                {
                    <ListItem>
                        <ListItemMeta Title="@templateItem.Name" Description="@templateItem.DiseaseName" />
                        <Button Size="@ButtonSize.Small" OnClick="() => UseTemplate(templateItem)">Use</Button>
                    </ListItem>
                }
            </List>
        </Card>
    </AntDesign.Col>
</AntDesign.Row>

@code {
    [Parameter]
    public int? AppointmentId { get; set; }

    private readonly List<AppointmentDetailsResponse> appointments = new();
    private readonly List<MedicineSearchResponse> medicines = new();
    private readonly List<DiseaseResponse> diseases = new();
    private readonly List<PrescriptionTemplateResponse> templates = new();
    private CreatePrescriptionRequest prescription = NewPrescription();
    private int selectedAppointmentId;
    private PatientHistoryResponse? history;
    private MedicalSummaryResponse? summary;
    private PrescriptionResponse? createdPrescription;
    private DateTime? followUpDate = DateTime.Today.AddDays(7);
    private string? followUpRecommendation;
    private string? message;
    private int currentStep = 0;
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        selectedAppointmentId = AppointmentId ?? 0;
        await Load();
        await SelectAppointment();
    }

    private async Task Load()
    {
        var apptResult = await Api.AppointmentsAsync(DateTime.UtcNow.Date.AddDays(-1), DateTime.UtcNow.Date.AddDays(7), pageSize: 100);
        var medResult = await Api.SearchMedicinesAsync(pageSize: 100);
        var diseaseResult = await Api.DiseasesAsync();
        var templateResult = await Api.PrescriptionTemplatesAsync();
        appointments.Clear();
        medicines.Clear();
        diseases.Clear();
        templates.Clear();
        appointments.AddRange(apptResult.Data);
        medicines.AddRange(medResult.Data);
        diseases.AddRange(diseaseResult.Data);
        templates.AddRange(templateResult.Data);
    }
    
    private void NextStep() => currentStep++;
    private void PrevStep() => currentStep--;

    private async Task SelectAppointmentHandler(AppointmentDetailsResponse appt)
    {
        selectedAppointmentId = appt?.Id ?? 0;
        await SelectAppointment();
    }

    private async Task SelectAppointment()
    {
        var appt = appointments.FirstOrDefault(a => a.Id == selectedAppointmentId);
        if (appt == null)
        {
            return;
        }

        prescription.AppointmentId = appt.Id;
        prescription.PatientId = appt.PatientId;
        history = (await Api.PatientHistoryAsync(appt.PatientId)).Data;
        summary = (await Api.MedicalSummaryAsync(appt.PatientId)).Data;
    }

    private void AddItem() => prescription.Items.Add(NewItem());

    private void RemoveItem(PrescriptionItemDto item)
    {
        if (prescription.Items.Count > 1)
        {
            prescription.Items.Remove(item);
        }
    }

    private async Task CreatePrescription()
    {
        isSubmitting = true;
        var result = await Api.CreatePrescriptionAsync(prescription);
        createdPrescription = result.Data;
        message = result.Message;
        if (result.IsSuccess && createdPrescription != null && !string.IsNullOrWhiteSpace(followUpRecommendation))
        {
            await Api.CreateFollowUpAsync(new FollowUpRequest
            {
                PatientId = prescription.PatientId,
                AppointmentId = prescription.AppointmentId,
                PrescriptionId = createdPrescription.Id,
                DueAt = followUpDate ?? DateTime.Today.AddDays(7),
                Recommendation = followUpRecommendation
            });
        }
        isSubmitting = false;
    }

    private async Task SaveTemplate()
    {
        var diseaseId = prescription.DiseaseId ?? diseases.FirstOrDefault()?.Id ?? 0;
        if (diseaseId <= 0)
        {
            message = "A disease is required before saving a template.";
            return;
        }

        var result = await Api.SavePrescriptionTemplateAsync(new SaveTemplateRequest
        {
            Name = $"Template {DateTime.Now:MMM-dd HH:mm}",
            DiseaseId = diseaseId,
            Items = prescription.Items.Select(i => new TemplateItemDto
            {
                MedicineId = i.MedicineId,
                Dosage = i.Dosage,
                Days = i.Days,
                Quantity = i.Quantity,
                Instruction = i.Instruction
            }).ToList()
        });
        message = result.Message;
        await Load();
    }

    private void UseTemplate(PrescriptionTemplateResponse template)
    {
        prescription.DiseaseId = template.DiseaseId;
        prescription.Items = template.Items.Select(i => new PrescriptionItemDto
        {
            MedicineId = i.MedicineId,
            Dosage = i.Dosage,
            Days = i.Days,
            Quantity = i.Quantity,
            DoseQuantity = 1,
            DoseUnit = "tablet",
            MealTiming = "after_meal",
            Route = "oral",
            Instruction = i.Instruction
        }).ToList();
    }

    private async Task DownloadPrescription(int prescriptionId)
    {
        var result = await Api.DownloadFileAsync($"api/prescriptions/{prescriptionId}/pdf", $"prescription-{prescriptionId}.pdf");
        message = result.IsSuccess ? null : result.Message;
    }

    private static CreatePrescriptionRequest NewPrescription()
        => new()
        {
            Items = { NewItem() }
        };

    private static PrescriptionItemDto NewItem()
        => new()
        {
            Days = 3,
            Quantity = 1,
            DoseQuantity = 1,
            DoseUnit = "tablet",
            MealTiming = "after_meal",
            Route = "oral"
        };
}
