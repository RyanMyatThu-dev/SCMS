@page "/follow-ups"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Follow-ups</PageTitle>

<section class="workspace-header">
    <div>
        <h1>Follow-ups</h1>
        <p>Recommendations and due reminders.</p>
    </div>
    <button class="secondary" @onclick="Load">Refresh</button>
</section>

<section class="table-surface">
    <table>
        <thead>
            <tr><th>Patient</th><th>Due</th><th>Recommendation</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var followUp in followUps)
            {
                <tr>
                    <td>@followUp.PatientName</td>
                    <td>@followUp.DueAt.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>@followUp.Recommendation</td>
                    <td><span class="badge @followUp.Status">@followUp.Status</span></td>
                    <td>
                        <AuthorizeView Roles="admin,doctor">
                            @if (followUp.Status != "completed")
                            {
                                <button @onclick="() => Complete(followUp.Id)">Complete</button>
                            }
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private readonly List<FollowUpResponse> followUps = new();

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        var result = await Api.FollowUpsAsync();
        followUps.Clear();
        followUps.AddRange(result.Data);
    }

    private async Task Complete(int id)
    {
        await Api.CompleteFollowUpAsync(id);
        await Load();
    }
}
