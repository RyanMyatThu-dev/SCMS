@page "/records"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Records</PageTitle>

<section class="workspace-header">
    <div>
        <h1>Medical records</h1>
        <p>Timeline, medical summary, prescriptions, invoices, and lab reports.</p>
    </div>
    <select class="field compact" @bind="selectedPatientId" @bind:after="LoadRecords">
        <option value="0">Select patient</option>
        @foreach (var patient in patients)
        {
            <option value="@patient.PatientId">@patient.Name</option>
        }
    </select>
</section>

@if (summary != null)
{
    <section class="metric-grid">
        <div class="metric"><span>Blood type</span><strong>@summary.BloodType</strong></div>
        <div class="metric warning"><span>Allergies</span><strong>@(summary.Allergies ?? "None")</strong></div>
        <div class="metric"><span>Vitals</span><strong>@summary.VitalsHistory.Count</strong></div>
        <div class="metric"><span>Active Rx</span><strong>@summary.ActivePrescriptions.Count</strong></div>
    </section>
    <div class="toolbar">
        <button class="secondary" type="button" @onclick="() => DownloadSummary(summary.PatientId)">Summary PDF</button>
        <button class="secondary" type="button" @onclick="() => PreviewSummary(summary.PatientId)">Preview HTML</button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(downloadMessage))
{
    <p class="status">@downloadMessage</p>
}

@if (!string.IsNullOrWhiteSpace(summaryHtml))
{
    <section class="item-card" style="margin-bottom: 22px;">
        <div class="split" style="align-items: center;">
            <h2 style="margin: 0;">Summary preview</h2>
            <button class="secondary" type="button" @onclick="ClosePreview">Close</button>
        </div>
        <div style="margin-top: 14px; border-top: 1px solid var(--line); padding-top: 14px; overflow: auto;">
            @((MarkupString)summaryHtml)
        </div>
    </section>
}

<section class="two-column">
    <div>
        <h2>Timeline</h2>
        <div class="list-stack">
            @foreach (var item in history?.Timeline ?? new List<TimelineItemDto>())
            {
                <article class="item-card">
                    <strong>@item.Type - @item.Title</strong>
                    <span>@item.Date.ToString("MMM dd, yyyy HH:mm")</span>
                    <p>@item.Description</p>
                </article>
            }
        </div>
    </div>
    <div>
        <h2>Frequently Prescribed Medications</h2>
        @if (frequentPatientMedicines.Count == 0)
        {
            <article class="item-card"><p style="color: var(--text-muted, #667085); margin: 0;">No medications prescribed yet.</p></article>
        }
        else
        {
            <div class="list-stack" style="margin-bottom: 24px;">
                @foreach (var med in frequentPatientMedicines)
                {
                    <article class="item-card" style="display: flex; justify-content: space-between; align-items: center; border-left: 4px solid var(--accent, #0052CC); padding: 12px 16px;">
                        <div>
                            <strong style="font-size: 15px; color: var(--text-main, #1D2939);">@med.MedicineName</strong>
                            <span style="font-size: 12px; color: var(--text-muted, #667085); display: block; margin-top: 4px;">Top historical medication</span>
                        </div>
                        <span style="background: #E0F2FE; color: #0369A1; padding: 4px 10px; border-radius: 999px; font-weight: bold; font-size: 12px;">@med.Count times</span>
                    </article>
                }
            </div>
        }

        <h2>Downloads</h2>
        <div class="list-stack">
            @foreach (var rx in prescriptions)
            {
                <article class="item-card">
                    <strong>Prescription #@rx.Id</strong>
                    <span>@rx.CreatedAt.ToString("MMM dd, yyyy")</span>
                    <button type="button" @onclick="() => DownloadPrescription(rx.Id)">Prescription PDF</button>
                </article>
            }

        </div>
    </div>
</section>

@code {
    private readonly List<PatientProfileResponse> patients = new();
    private readonly List<PrescriptionResponse> prescriptions = new();

    private int selectedPatientId;
    private PatientHistoryResponse? history;
    private MedicalSummaryResponse? summary;
    private string? downloadMessage;
    private string? summaryHtml;
    private List<(string MedicineName, int Count)> frequentPatientMedicines = new();

    [SupplyParameterFromQuery]
    public int? PatientId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var result = await Api.PatientProfilesAsync();
        patients.AddRange(result.Data);
        selectedPatientId = PatientId ?? patients.FirstOrDefault()?.PatientId ?? 0;
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        if (selectedPatientId <= 0)
        {
            return;
        }

        history = (await Api.PatientHistoryAsync(selectedPatientId)).Data;
        summary = (await Api.MedicalSummaryAsync(selectedPatientId)).Data;
        var rx = await Api.PrescriptionsAsync(selectedPatientId);
        prescriptions.Clear();
        prescriptions.AddRange(rx.Data);
        summaryHtml = null;

        frequentPatientMedicines = prescriptions
            .SelectMany(p => p.Items)
            .GroupBy(i => i.MedicineName)
            .Select(g => (MedicineName: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count)
            .Take(5)
            .ToList();
    }

    private async Task DownloadAsync(string relativePath, string fileName)
    {
        var result = await Api.DownloadFileAsync(relativePath, fileName);
        downloadMessage = result.IsSuccess ? null : result.Message;
    }

    private Task DownloadSummary(int patientId)
        => DownloadAsync($"api/patients/{patientId}/summary/pdf", $"medical-summary-{patientId}.pdf");

    private async Task PreviewSummary(int patientId)
    {
        var result = await Api.MedicalSummaryHtmlAsync(patientId);
        summaryHtml = result.IsSuccess ? result.Data : null;
        downloadMessage = result.IsSuccess ? null : result.Message;
    }

    private void ClosePreview()
    {
        summaryHtml = null;
    }

    private Task DownloadPrescription(int prescriptionId)
        => DownloadAsync($"api/prescriptions/{prescriptionId}/pdf", $"prescription-{prescriptionId}.pdf");

}
