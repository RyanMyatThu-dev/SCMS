@page "/notifications"
@attribute [Authorize]
@inject ApiClient Api
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject RealtimeClient Realtime
@implements IDisposable

<PageTitle>Notifications</PageTitle>

<section class="workspace-header">
    <div>
        <h1>Notifications</h1>
        <p>Clinic notices, queue alerts, and follow-up reminders.</p>
    </div>
    <div class="toolbar">
        @if (isStaff)
        {
            <label style="margin: 0; display: inline-flex; align-items: center; gap: 6px;">
                <input type="checkbox" @bind="includeAll" @bind:after="Load" />
                All clinic notices
            </label>
        }
        <button class="secondary" @onclick="Load">Refresh</button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <Alert Type="@AlertType.Info" Message="@message" ShowIcon="true" Closable OnClose="ClearMessage" Style="margin-bottom: 16px;" />
}

<section class="two-column wide-left">
    <div>
        <h2>Inbox</h2>
        <div class="list-stack">
            @if (notifications.Count == 0)
            {
                <div class="empty-state">No notifications found.</div>
            }
            else
            {
                @foreach (var notification in notifications)
                {
                    <article class="item-card">
                        <div class="split" style="align-items: flex-start;">
                            <div>
                                <strong>@notification.Title</strong>
                                <span>@notification.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <button type="button" class="secondary" @onclick="() => MarkRead(notification.Id)">Mark read</button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(notification.Description))
                        {
                            <p>@notification.Description</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(notification.ActionRoute))
                        {
                            <a href="@notification.ActionRoute">Open related screen</a>
                        }
                    </article>
                }
            }
        </div>
    </div>

    <AuthorizeView Roles="owner">
        <Authorized Context="notificationAuth">
            <div>
                <h2>Create notice</h2>
                <div class="item-card">
                    <EditForm Model="form" OnValidSubmit="Create">
                        <label>User ID</label>
                        <Microsoft.AspNetCore.Components.Forms.InputNumber class="field" @bind-Value="form.UserId" />
                        <label>Title</label>
                        <InputText class="field" @bind-Value="form.Title" />
                        <label>Description</label>
                        <InputTextArea class="field" @bind-Value="form.Description" />
                        <label>Action route</label>
                        <InputText class="field" @bind-Value="form.ActionRoute" />
                        <button class="primary" type="submit" style="margin-top: 12px;">Send notice</button>
                    </EditForm>
                    <p style="margin-top: 10px;">Leave User ID empty to broadcast to staff-visible clinic notices.</p>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>
</section>

@code {
    private readonly List<NotificationResponse> notifications = new();
    private readonly CreateNotificationRequest form = new();
    private bool includeAll;
    private bool isStaff;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isStaff = authState.User.IsInRole("owner");
        
        Realtime.NotificationsChanged += RefreshInbox;
        Realtime.OnNotificationReceived += HandleNotificationReceived;
        
        await Load();
    }

    private void RefreshInbox()
    {
        _ = InvokeAsync(async () =>
        {
            await Load();
            StateHasChanged();
        });
    }

    private void HandleNotificationReceived(NotificationResponse n)
    {
        _ = InvokeAsync(async () =>
        {
            await Load();
            StateHasChanged();
        });
    }

    private async Task Load()
    {
        var result = await Api.GetNotificationsAsync(includeAll && isStaff, pageSize: 100);
        notifications.Clear();
        notifications.AddRange(result.Data);
        message = result.IsSuccess ? null : result.Message;
    }

    private async Task MarkRead(int id)
    {
        var result = await Api.MarkNotificationAsReadAsync(id);
        message = result.Message;
        if (result.IsSuccess)
        {
            await Load();
        }
    }

    private async Task Create()
    {
        if (string.IsNullOrWhiteSpace(form.Title) || string.IsNullOrWhiteSpace(form.Description))
        {
            message = "Title and description are required.";
            return;
        }

        var result = await Api.CreateNotificationAsync(form);
        message = result.Message;
        if (result.IsSuccess)
        {
            form.UserId = null;
            form.Title = string.Empty;
            form.Description = string.Empty;
            form.ActionRoute = null;
            await Load();
        }
    }

    private void ClearMessage()
    {
        message = null;
    }

    public void Dispose()
    {
        Realtime.NotificationsChanged -= RefreshInbox;
        Realtime.OnNotificationReceived -= HandleNotificationReceived;
    }
}
