@page "/diseases"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Diseases</PageTitle>
<PageHeader Title="Disease Management" Subtitle="View and manage medical conditions" />

<div style="margin-bottom: 16px; display: flex; gap: 8px; flex-wrap: wrap;">
    <div style="display: flex; align-items: center; gap: 8px;">
        <span>Filter:</span>
        <AntDesign.Input @bind-Value="searchQuery" Placeholder="Search diseases..." Style="width: 200px;" />
    </div>
    <AuthorizeView Roles="admin,doctor">
        <Authorized>
            <Button Type="@ButtonType.Primary" OnClick="ShowCreateModal">Add Disease</Button>
        </Authorized>
    </AuthorizeView>
</div>

@if (isLoading)
{
    <AntDesign.Spin />
}
else if (diseases == null || diseases.Count == 0)
{
    <Alert Type="@AlertType.Info" Message="No diseases found. Click 'Add Disease' to create one." ShowIcon="true" />
}
else
{
    <Table TItem="DiseaseResponse" DataSource="diseases" Size="TableSize.Small" Bordered>
        <Column TData="int" Title="ID">
            @context.Id
        </Column>
        <Column TData="string" Title="Name">
            @context.Name
        </Column>
        <Column TData="string" Title="Description">
            @(context.Description ?? "-")
        </Column>
        <Column TData="string" Title="Actions">
            <AuthorizeView Roles="admin,doctor" Context="authContext">
                <Authorized>
                    <Space>
                        <SpaceItem>
                            <Button Type="@ButtonType.Default" Size="@ButtonSize.Small" OnClick="() => ShowEditModal(context)">
                                Edit
                            </Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Button Type="@ButtonType.Default" Size="@ButtonSize.Small" OnClick="() => ShowTemplatesModal(context)">
                                Templates
                            </Button>
                        </SpaceItem>
                        <SpaceItem>
                            <Button Danger Size="@ButtonSize.Small" OnClick="() => ConfirmDelete(context.Id, context.Name)">
                                Deactivate
                            </Button>
                        </SpaceItem>
                    </Space>
                </Authorized>
            </AuthorizeView>
        </Column>
    </Table>
}

<AntDesign.Modal Visible="@showCreateModal" 
                 Title="@(editingDisease == null ? "Add New Disease" : "Edit Disease")" 
                 OnCancel="HideCreateModal" 
                 OnOk="HandleSave" 
                 OkText="@("Save")" 
                 CancelText="@("Cancel")">
    <div>
        <AntDesign.Form Model="@diseaseForm" @ref="formRef" Layout="FormLayout.Vertical" TModel="DiseaseFormDto">
            <AntDesign.FormItem Label="Name">
                <AntDesign.Input @bind-Value="diseaseForm.Name" />
                <AntDesign.FormItem.ValidateMessages>
                    @if (!string.IsNullOrEmpty(nameError))
                    {
                        <div class="ant-form-item-explain-error" style="color: #ff4d4f;">@nameError</div>
                    }
                </AntDesign.FormItem.ValidateMessages>
            </AntDesign.FormItem>
            <AntDesign.FormItem Label="Description">
                <AntDesign.TextArea @bind-Value="diseaseForm.Description" Rows="3" />
            </AntDesign.FormItem>
        </AntDesign.Form>
    </div>
</AntDesign.Modal>

<AntDesign.Modal Visible="@showDeleteModal" 
                 Title="Confirm Deactivation" 
                 OnCancel="HideDeleteModal" 
                 OnOk="HandleConfirmDelete" 
                 OkText="@("Confirm")" 
                 CancelText="@("Cancel")">
    <p>Are you sure you want to deactivate "<strong>@diseaseToDelete?.Name</strong>"?</p>
    <p>This will remove it from selection lists and cannot be undone easily.</p>
</AntDesign.Modal>

<AntDesign.Modal Visible="@showTemplatesModal" 
                 Title="@($"Prescription Templates for {selectedDiseaseForTemplates?.Name}")" 
                 OnCancel="HideTemplatesModal" 
                 Footer="null"
                 Width="800">
    <div>
        @if (isTemplatesLoading)
        {
            <AntDesign.Spin />
        }
        else
        {
            @if (!showCreateCustomTemplateForm)
            {
                <div style="margin-bottom: 16px; text-align: right;">
                    <Button Type="@ButtonType.Primary" OnClick="ShowCreateCustomTemplate">
                        + Create Custom Template
                    </Button>
                </div>

                @if (diseaseTemplates == null || diseaseTemplates.Count == 0)
                {
                    <Alert Type="@AlertType.Info" Message="No prescription templates defined for this disease yet. You can create one above!" ShowIcon="true" />
                }
                else
                {
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        @foreach (var tpl in diseaseTemplates)
                        {
                            <div style="background: #ffffff; border: 1px solid #e4e7ec; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05); padding: 20px; transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; gap: 12px;">
                                <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid #f2f4f7; padding-bottom: 12px; margin-bottom: 4px;">
                                    <div>
                                        <h4 style="margin: 0 0 4px 0; font-size: 16px; font-weight: 700; color: #1d2939; display: flex; align-items: center; gap: 8px;">
                                            <span style="width: 8px; height: 8px; border-radius: 50%; background: #6172F3;"></span>
                                            @tpl.Name
                                        </h4>
                                        <span style="font-size: 12px; color: #667085; display: inline-flex; align-items: center; gap: 4px;">
                                            <Icon Type="tags" />
                                            @tpl.DiseaseName
                                        </span>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <span style="font-size: 11px; font-weight: 600; color: #344054; background: #f2f4f7; padding: 4px 10px; border-radius: 9999px;">
                                            @(tpl.Items?.Count ?? 0) @(tpl.Items?.Count == 1 ? "Medicine" : "Medicines")
                                        </span>
                                        <Button Size="@ButtonSize.Small" Type="@ButtonType.Primary" Ghost OnClick="() => ShowEditCustomTemplate(tpl)">
                                            Edit
                                        </Button>
                                    </div>
                                </div>
                                
                                <div style="display: flex; flex-direction: column; gap: 8px;">
                                    @if (tpl.Items != null && tpl.Items.Any())
                                    {
                                        @foreach (var item in tpl.Items)
                                        {
                                            <div style="background: #f8f9fc; border-left: 3px solid #6172F3; padding: 10px 14px; border-radius: 0 8px 8px 0; display: flex; justify-content: space-between; align-items: center; gap: 12px;">
                                                <div style="flex: 1;">
                                                    <span style="font-weight: 600; color: #344054; font-size: 14px; display: block;">@item.MedicineName</span>
                                                    @if (!string.IsNullOrWhiteSpace(item.Instruction))
                                                    {
                                                        <span style="font-size: 12px; color: #667085; font-style: italic; display: inline-flex; align-items: center; gap: 4px; margin-top: 2px;">
                                                            <Icon Type="info-circle" />
                                                            @item.Instruction
                                                        </span>
                                                    }
                                                </div>
                                                <div style="text-align: right; font-size: 13px; color: #475467; min-width: 140px;">
                                                    <span style="background: #eef4ff; color: #3538CD; padding: 2px 8px; border-radius: 4px; font-weight: 600; margin-right: 4px;">@item.Dosage</span>
                                                    for <strong>@item.Days d</strong> (@item.Quantity qty)
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color: #98a2b3; font-style: italic; font-size: 13px;">No medicines in this template.</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div style="border: 1px solid #EAECF0; padding: 18px; border-radius: 12px; background: #FFF;">
                    <h3 style="margin-bottom: 16px; font-weight: 700; color: #1D2939;">
                        @(editingTemplateId.HasValue ? "Edit Prescription Template" : "Create New Prescription Template")
                    </h3>
                    
                    <div style="margin-bottom: 16px;">
                        <span style="font-weight: bold; display: block; margin-bottom: 8px;">Template Name</span>
                        <Input @bind-Value="newTemplateName" Placeholder="e.g. URI Fever Standard Protocol" />
                    </div>

                    <div style="margin-bottom: 16px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                            <span style="font-weight: bold;">Medicines</span>
                            <Button Size="@ButtonSize.Small" OnClick="AddMedicineToNewTemplate">Add Medicine</Button>
                        </div>

                        <Table TItem="TemplateItemFormDto" DataSource="newTemplateItems" Size="TableSize.Small">
                            <Column TData="int" Title="Medicine">
                                <Select TItem="MedicineSearchResponse" TItemValue="int" @bind-Value="context.MedicineId" 
                                        DataSource="allMedicines" ValueName="@nameof(MedicineSearchResponse.MedicineId)" LabelName="@nameof(MedicineSearchResponse.Name)" 
                                        Style="width: 100%;" Placeholder="Select Medicine" EnableSearch />
                            </Column>
                            <Column TData="int" Title="Qty">
                                <AntDesign.InputNumber @bind-Value="context.Quantity" Style="width: 70px;" Min="1" />
                            </Column>
                            <Column TData="int" Title="Days">
                                <AntDesign.InputNumber @bind-Value="context.Days" Style="width: 70px;" Min="1" />
                            </Column>
                            <Column TData="string" Title="Dosage">
                                <Input @bind-Value="context.Dosage" Placeholder="e.g. 500 mg" />
                            </Column>
                            <Column TData="string" Title="Instruction">
                                <Input @bind-Value="context.Instruction" Placeholder="e.g. after meal" />
                            </Column>
                            <ActionColumn Title="Action">
                                <Button Danger Size="@ButtonSize.Small" OnClick="() => RemoveMedicineFromNewTemplate(context)">X</Button>
                            </ActionColumn>
                        </Table>
                    </div>

                    @if (!string.IsNullOrEmpty(newTemplateError))
                    {
                        <Alert Type="@AlertType.Error" Message="@newTemplateError" ShowIcon="true" Style="margin-bottom: 16px;" />
                    }

                    <div style="text-align: right; margin-top: 16px;">
                        <Space>
                            <SpaceItem><Button OnClick="CancelCreateCustomTemplate">Cancel</Button></SpaceItem>
                            <SpaceItem><Button Type="@ButtonType.Primary" OnClick="SaveCustomTemplate" Loading="isSavingTemplate">Save Template</Button></SpaceItem>
                        </Space>
                    </div>
                </div>
            }
        }
    </div>
</AntDesign.Modal>

@code {
    private List<DiseaseResponse> diseases = new();
    private bool isLoading = true;
    private string searchQuery = "";

    // Form state
    private DiseaseFormDto diseaseForm = new();
    private bool showCreateModal = false;
    private DiseaseResponse? editingDisease = null;
    private Form<DiseaseFormDto>? formRef; 
    private string? nameError;

    // Delete state
    private DiseaseResponse? diseaseToDelete = null;
    private bool showDeleteModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDiseases();
    }

    private async Task LoadDiseases()
    {
        isLoading = true;
        try
        {
            var result = await Api.DiseasesAsync(searchQuery);
            if (result.IsSuccess)
            {
                diseases = result.Data;
            }
            else
            {
                diseases = new();
            }
        }
        catch (Exception)
        {
            diseases = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateModal()
    {
        editingDisease = null;
        diseaseForm = new DiseaseFormDto();
        nameError = null;
        showCreateModal = true;
    }

    private void ShowEditModal(DiseaseResponse disease)
    {
        editingDisease = disease;
        diseaseForm = new DiseaseFormDto
        {
            Name = disease.Name,
            Description = disease.Description ?? ""
        };
        nameError = null;
        showCreateModal = true;
    }

    private void HideCreateModal()
    {
        showCreateModal = false;
        editingDisease = null;
        diseaseForm = new DiseaseFormDto();
        nameError = null;
        if (formRef != null)
        {
            formRef.Reset();
        }
    }

    private async Task HandleSave()
    {
        if (formRef == null) return;

        if (string.IsNullOrWhiteSpace(diseaseForm.Name))
        {
            nameError = "Disease name is required";
            return;
        }

        nameError = null;

        try
        {
            Result<DiseaseResponse> result;
            if (editingDisease == null)
            {
                var createRequest = new CreateDiseaseRequest
                {
                    Name = diseaseForm.Name.Trim(),
                    Description = string.IsNullOrWhiteSpace(diseaseForm.Description) ? null : diseaseForm.Description.Trim()
                };
                result = await Api.CreateDiseaseAsync(createRequest);
            }
            else
            {
                var updateRequest = new UpdateDiseaseRequest
                {
                    Id = editingDisease.Id,
                    Name = diseaseForm.Name.Trim(),
                    Description = string.IsNullOrWhiteSpace(diseaseForm.Description) ? null : diseaseForm.Description.Trim()
                };
                result = await Api.UpdateDiseaseAsync(updateRequest);
            }

            if (result.IsSuccess)
            {
                await LoadDiseases();
                HideCreateModal();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving disease: {ex.Message}");
        }
    }

    private void ConfirmDelete(int id, string name)
    {
        diseaseToDelete = diseases.FirstOrDefault(d => d.Id == id);
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        diseaseToDelete = null;
    }

    private async Task HandleConfirmDelete()
    {
        if (diseaseToDelete == null) return;

        try
        {
            var result = await Api.DeactivateDiseaseAsync(diseaseToDelete.Id);

            if (result.IsSuccess)
            {
                await LoadDiseases();
                HideDeleteModal();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting disease: {ex.Message}");
        }
    }

    // Templates state
    private bool showTemplatesModal = false;
    private DiseaseResponse? selectedDiseaseForTemplates = null;
    private List<PrescriptionTemplateResponse> diseaseTemplates = new();
    private int? editingTemplateId = null;
    private bool isTemplatesLoading = false;

    // Custom template creation state
    private bool showCreateCustomTemplateForm = false;
    private string newTemplateName = "";
    private List<TemplateItemFormDto> newTemplateItems = new();
    private List<MedicineSearchResponse> allMedicines = new();
    private string? newTemplateError = null;
    private bool isSavingTemplate = false;

    private async Task ShowTemplatesModal(DiseaseResponse disease)
    {
        selectedDiseaseForTemplates = disease;
        showTemplatesModal = true;
        showCreateCustomTemplateForm = false;
        newTemplateError = null;
        editingTemplateId = null;
        StateHasChanged();
        await LoadDiseaseTemplates();
    }

    private void HideTemplatesModal()
    {
        showTemplatesModal = false;
        selectedDiseaseForTemplates = null;
        editingTemplateId = null;
        diseaseTemplates.Clear();
    }

    private async Task LoadDiseaseTemplates()
    {
        if (selectedDiseaseForTemplates == null) return;
        isTemplatesLoading = true;
        try
        {
            var result = await Api.PrescriptionTemplatesAsync(selectedDiseaseForTemplates.Id);
            if (result.IsSuccess)
            {
                diseaseTemplates = result.Data;
            }
            else
            {
                diseaseTemplates = new();
            }
        }
        catch (Exception)
        {
            diseaseTemplates = new();
        }
        finally
        {
            isTemplatesLoading = false;
            StateHasChanged();
        }
    }

    private async Task ShowCreateCustomTemplate()
    {
        newTemplateName = $"{selectedDiseaseForTemplates?.Name} Protocol";
        newTemplateItems.Clear();
        newTemplateItems.Add(new TemplateItemFormDto { Quantity = 1, Days = 3, Dosage = "1 tablet", Instruction = "after meal" });
        newTemplateError = null;
        
        try
        {
            var medsResult = await Api.SearchMedicinesAsync(pageSize: 100);
            if (medsResult.IsSuccess)
            {
                allMedicines = medsResult.Data;
            }
        }
        catch (Exception)
        {
            allMedicines = new();
        }

        showCreateCustomTemplateForm = true;
    }

    private void CancelCreateCustomTemplate()
    {
        showCreateCustomTemplateForm = false;
        newTemplateError = null;
        editingTemplateId = null;
    }

    private void AddMedicineToNewTemplate()
    {
        newTemplateItems.Add(new TemplateItemFormDto { Quantity = 1, Days = 3, Dosage = "1 tablet", Instruction = "after meal" });
    }

    private void RemoveMedicineFromNewTemplate(TemplateItemFormDto item)
    {
        if (newTemplateItems.Count > 1)
        {
            newTemplateItems.Remove(item);
        }
    }

    private async Task ShowEditCustomTemplate(PrescriptionTemplateResponse tpl)
    {
        editingTemplateId = int.Parse(tpl.Id);
        newTemplateName = tpl.Name;
        newTemplateItems.Clear();
        
        foreach (var item in tpl.Items)
        {
            newTemplateItems.Add(new TemplateItemFormDto
            {
                MedicineId = item.MedicineId,
                Quantity = item.Quantity,
                Days = item.Days,
                Dosage = item.Dosage ?? "1 tablet",
                Instruction = item.Instruction ?? "after meal"
            });
        }
        
        newTemplateError = null;

        try
        {
            var medsResult = await Api.SearchMedicinesAsync(pageSize: 100);
            if (medsResult.IsSuccess)
            {
                allMedicines = medsResult.Data;
            }
        }
        catch (Exception)
        {
            allMedicines = new();
        }

        showCreateCustomTemplateForm = true;
    }

    private async Task SaveCustomTemplate()
    {
        if (selectedDiseaseForTemplates == null) return;

        if (string.IsNullOrWhiteSpace(newTemplateName))
        {
            newTemplateError = "Template name is required.";
            return;
        }

        if (newTemplateItems.Any(i => i.MedicineId <= 0))
        {
            newTemplateError = "Please select a valid medicine for every item.";
            return;
        }

        isSavingTemplate = true;
        newTemplateError = null;

        try
        {
            var request = new SaveTemplateRequest
            {
                Id = editingTemplateId,
                Name = newTemplateName.Trim(),
                DiseaseId = selectedDiseaseForTemplates.Id,
                Items = newTemplateItems.Select(i => new TemplateItemDto
                {
                    MedicineId = i.MedicineId,
                    Dosage = i.Dosage,
                    Days = i.Days,
                    Quantity = i.Quantity,
                    Instruction = i.Instruction
                }).ToList()
            };

            var result = await Api.SavePrescriptionTemplateAsync(request);
            if (result.IsSuccess)
            {
                showCreateCustomTemplateForm = false;
                editingTemplateId = null;
                await LoadDiseaseTemplates();
            }
            else
            {
                newTemplateError = result.Message;
            }
        }
        catch (Exception ex)
        {
            newTemplateError = $"Error saving template: {ex.Message}";
        }
        finally
        {
            isSavingTemplate = false;
        }
    }

    private class TemplateItemFormDto
    {
        public int MedicineId { get; set; }
        public int Quantity { get; set; }
        public int Days { get; set; }
        public string Dosage { get; set; } = "1 tablet";
        public string Instruction { get; set; } = "after meal";
    }

    private class DiseaseFormDto
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
    }
}