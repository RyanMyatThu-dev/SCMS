@page "/payments"
@attribute [Authorize(Roles = "owner")]
@inject ApiClient Api

<PageTitle>Payments</PageTitle>

<section class="workspace-header">
    <div>
        <h1>Manual payment verification</h1>
        <p>Proof uploads waiting for clinic approval.</p>
    </div>
    <button class="secondary" @onclick="Load">Refresh</button>
</section>

<section class="table-surface">
    <table>
        <thead>
            <tr><th>Appointment</th><th>Patient</th><th>Amount</th><th>Method</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var payment in payments)
            {
                <tr>
                    <td>@payment.AppointmentCode</td>
                    <td>@payment.PatientName</td>
                    <td>@payment.Amount.ToString("N0")</td>
                    <td>@payment.PaymentMethod</td>
                    <td><span class="badge @payment.PaymentStatus">@payment.PaymentStatus</span></td>
                    <td class="actions">
                        <button type="button" @onclick="() => DownloadInvoice(payment.Id)">PDF</button>
                        @if (payment.PaymentStatus != "paid")
                        {
                            <button @onclick="() => Approve(payment.Id)">Approve</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p class="status">@message</p>
}

@code {
    private readonly List<PaymentDetailsResponse> payments = new();
    private string? message;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        var result = await Api.PaymentsAsync();
        payments.Clear();
        payments.AddRange(result.Data);
    }

    private async Task Approve(int id)
    {
        var result = await Api.ApprovePaymentAsync(id);
        message = result.Message;
        await Load();
    }

    private async Task DownloadInvoice(int id)
    {
        var result = await Api.DownloadFileAsync($"api/payments/{id}/invoice/pdf", $"invoice-{id}.pdf");
        message = result.IsSuccess ? null : result.Message;
    }
}
