{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=scms.local.db",
    "PostgreSqlConnection": "Host=localhost;Database=SCMS_db;Username=postgres;Password=admin"
  },
  "Database": {
    "Provider": "PostgreSql",
    "EnsureCreated": true,
    "SeedDemoUsers": true,
    "SeedRealWorldData": true
  },
  "Cloudinary": {
    "CloudName": "dynwrqygo"
  },
  "Jwt": {
    "Issuer": "SCMS.Api",
    "Audience": "SCMS.Web",
    "SigningKey": "SCMS local development signing key 2026 - replace with a secret",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Gemini": {
  },
  "AllowedHosts": "*"
}
