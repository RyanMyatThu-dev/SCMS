    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>d3131a60-46c0-411e-8208-e752aa143f2b</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="scms.local.db" />
